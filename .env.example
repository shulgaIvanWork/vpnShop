# MAX VPN Shop Bot - Environment Variables Template
# Copy this file to .env and fill in your values

# MAX Bot
MAX_BOT_TOKEN=
BOT_ADMINS=
BOT_DEV_ID=
BOT_DOMAIN=
BOT_PORT=8080

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_TOKEN=

# YooMoney
YOOMONEY_WALLET_ID=
YOOMONEY_NOTIFICATION_SECRET=

# PostgreSQL
POSTGRES_USER=vpn_user
POSTGRES_PASSWORD=
POSTGRES_DB=vpn_shop
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# 3X-UI Panel
XUI_USERNAME=admin
XUI_PASSWORD=
XUI_URL=http://localhost:2053
XUI_SUBSCRIPTION_PORT=2096
XUI_SUBSCRIPTION_PATH=/sub/

# DeepSeek AI
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=500
DEEPSEEK_TEMPERATURE=0.7

# Security
ENCRYPTION_KEY=

# Shop
SHOP_EMAIL=
SHOP_CURRENCY=RUB

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s
